fn test_downcasts(): i32 {
    // i32 -> u8
    let a: i32 = 258;
    let b: u8 = a as u8;
    if b != 2 return 1;

    // u64 -> u32
    let c: u64 = 4294967297; // 2^32 + 1
    let d: u32 = c as u32;
    if d != 1 return 2;

    // i16 -> bool (truncates to u8/bool)
    let e: i16 = 256; // 0x0100 -> lowest byte is 0
    let f: bool = e as bool;
    if f != false return 3;

    let g: i16 = 257; // 0x0101 -> lowest byte is 1
    let h: bool = g as bool;
    if h != true return 4;

    0
}

fn test_upcasts_unsigned(): i32 {
    // u8 -> i32 (zero extension)
    let a: u8 = 255;
    let b: i32 = a as i32;
    if b != 255 return 5;

    // bool -> i32 (zero extension)
    let c: bool = true;
    let d: i32 = c as i32;
    if d != 1 return 6;

    let e: bool = false;
    let f: i32 = e as i32;
    if f != 0 return 7;

    // char -> u32 (zero extension)
    let g: char = 'A';
    let h: u32 = g as u32;
    if h != 65 return 8;

    0
}

fn test_upcasts_signed(): i32 {
    // i8 -> i32 (sign extension)
    let a: i8 = -1;
    let b: i32 = a as i32;
    if b != -1 return 9;

    // i8 -> i64 (sign extension)
    let c: i8 = -128;
    let d: i64 = c as i64;
    if d != -128 return 10;

    // i16 -> i64 (sign extension)
    let e: i16 = -32768;
    let f: i64 = e as i64;
    if f != -32768 return 11;

    0
}

fn test_same_size(): i32 {
    // i32 -> u32
    let a: i32 = -1;
    let b: u32 = a as u32;
    if b != 4294967295 return 12;

    // u32 -> i32
    let c: u32 = 4294967295;
    let d: i32 = c as i32;
    if d != -1 return 13;

    let e: char = 'Z'; // ascii 90
    let f: i32 = e as i32;
    if f != 90 return 14;

    // bool -> u8
    let g: bool = true;
    let h: u8 = g as u8;
    if h != 1 return 15;

    0
}

fn main(): i32 {
    let r1 = test_downcasts();
    if r1 != 0 return r1;

    let r2 = test_upcasts_unsigned();
    if r2 != 0 return r2;

    let r3 = test_upcasts_signed();
    if r3 != 0 return r3;

    let r4 = test_same_size();
    if r4 != 0 return r4;

    42
}

use std::cmp::{PartialEq};
use std::default::{Default};
use std::mem;

enum Status {
    Ready = 1,
    Done = 2,
} as u8

struct PackedFlags {
    a: i8,
    b: i64,
    c: i32,
} as packed, align(4)

impl Status {
    fn code(&self): u8 { 7 }

    fn touch(&mut self): u8 { 9 }
}

impl Status with Default {
    fn default(): Self {
        Status::Ready
    }
}

impl Status with PartialEq {
    fn eq(&self, other: &Self): bool {
        true
    }
}

fn main(): i32 {
    let mut status = Status::default();
    let other = Status::Done;

    // TODO: correct std::panic::assert to be used in testing instead of those ifs

    if mem::size_of(Status) != 1 return 1;
    if mem::align_of(Status) != 1 return 2;
    if mem::size_of(PackedFlags) != 16 return 6;
    if mem::align_of(PackedFlags) != 4 return 7;
    if !status.eq(&other) return 3;
    if status.touch() != 9 return 4;
    if status.code() != 7 return 5;
    0
}

struct Vector {
    x: i64,
    y: i64,
}

fn main(): i64 {
    let mut v = Vector { x: 3, y: 4 };
    let u = Vector { x: 5, y: 10 };

    v.x = 2;

    // (2*5) + (4*10) = 50
    let result = dot_product(v, u);
    if result != 50 return 1;

    0
}

fn dot_product(a: Vector, b: Vector): i64 {
    (a.x * b.x) + (a.y * b.y)
}

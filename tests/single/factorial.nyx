// factorial — iterative
//
// computes n! using a range loop and a mutable accumulator.
// avoids recursion to show the imperative style.
//
// exit code: factorial(7) = 5040 ... too large for a byte exit code.
// we use factorial(5) = 120 instead — still visible in $?

fn factorial(n: i32): i32 {
    let mut result: i32 = 1;
    loop i in 2..=n {
        result = result * i;
    }

    result
}

fn main(): i32 {
    factorial(5)
}

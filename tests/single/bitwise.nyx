fn test_not(): i32 {
    let a: i32 = !1;
    if a != -2 return 1;

    let b: i8 = !0;
    if b != -1 return 2;

    let c: bool = !true;
    if c != false return 3;

    let d: bool = !false;
    if d != true return 4;

    0
}

fn test_and(): i32 {
    let a: i32 = 5 & 3;
    if a != 1 return 5;

    let b: bool = true & false;
    if b != false return 6;

    let c: bool = true & true;
    if c != true return 7;

    0
}

fn test_or(): i32 {
    let a: i32 = 5 | 3;
    if a != 7 return 8;

    let b: bool = true | false;
    if b != true return 9;

    0
}

fn test_xor(): i32 {
    let a: i32 = 5 ^ 3;
    if a != 6 return 10;

    let b: bool = true ^ false;
    if b != true return 11;

    let c: bool = true ^ true;
    if c != false return 12;

    0
}

fn test_shl(): i32 {
    let a: i32 = 2 << 3;
    if a != 16 return 13;

    // variable shifts
    let base: i32 = 3;
    let amt: i32 = 2;
    let b: i32 = base << amt;
    if b != 12 return 14;

    // 64-bit shl
    let val: i64 = 1;
    let c: i64 = val << 30;
    // 1 << 30 is 1073741824
    if c != 1073741824 return 15;

    0
}

fn test_shr(): i32 {
    // signed arithmetic shift right (negative)
    let a: i32 = -8 >> 2;
    if a != -2 return 16;

    // signed arithmetic shift right (positive)
    let b: i32 = 8 >> 2;
    if b != 2 return 17;

    // unsigned logical shift right
    let uval: u8 = 128;
    let c: u8 = uval >> 3;
    if c != 16 return 18;

    // variable shift right signed
    let val_s: i32 = -16;
    let amt_s: i32 = 3;
    let d: i32 = val_s >> amt_s;
    if d != -2 return 19;

    // variable shift right unsigned
    let val_u: u32 = 4294967295; // u32::MAX
    let amt_u: u32 = 31;
    let e: u32 = val_u >> amt_u;
    if e != 1 return 20;

    0
}

fn main(): i32 {
    let r1 = test_not();
    if r1 != 0 return r1;

    let r2 = test_and();
    if r2 != 0 return r2;

    let r3 = test_or();
    if r3 != 0 return r3;

    let r4 = test_xor();
    if r4 != 0 return r4;

    let r5 = test_shl();
    if r5 != 0 return r5;

    let r6 = test_shr();
    if r6 != 0 return r6;

    // exit code 42 to verify it actually ran and returned expected
    42
}

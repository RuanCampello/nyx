use std::default::{Default};
use std::cmp::{PartialEq};

struct Point {
    x: i32,
    y: i32,
}

impl Point with Default {
    fn default(): Self {
        Point { x: 0, y: 0 }
    }
}

impl Point with PartialEq<Point> {
    fn eq(&self, other: &Point): bool {
        self.x == other.x && self.y == other.y
    }
}

fn main(): i32 {
    let p1 = Point::default();
    let p2 = Point { x: 0, y: 0 };
    let p3 = Point { x: 1, y: 2 };

    if !p1.eq(&p2) return 1;
    if p1.ne(&p3) == false return 2;
    if p2.eq(&p3) return 3;

    0
}
